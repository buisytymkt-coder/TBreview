# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:YOUR_TOKEN

# Chat ID where notifications will be sent (group/channel/user)
TELEGRAM_CHAT_ID=-1001234567890

# TikTok Shop Seller Center rating page
TIKTOK_RATING_URL=https://seller-us.tiktok.com/product/rating?shop_region=US

# Poll interval in seconds
POLL_SECONDS=300

# Number of top rows to parse each run
MAX_ROWS=30

# Time to wait for manual login/captcha before timeout (seconds)
LOGIN_WAIT_SECONDS=300

# Retry when TikTok page shows "Network error"
NETWORK_ERROR_RETRY_COUNT=4
NETWORK_ERROR_RETRY_DELAY_SECONDS=5

# Optional: proxy for TikTok requests (recommended on VPS)
# Examples:
# TIKTOK_PROXY_SERVER=http://host:port
# TIKTOK_PROXY_SERVER=socks5://host:port
TIKTOK_PROXY_SERVER=
TIKTOK_PROXY_USERNAME=
TIKTOK_PROXY_PASSWORD=

# Optional: path to cookie JSON to skip manual login, e.g. cookies.json
TIKTOK_COOKIES_FILE=

# Set true to send startup status message
SEND_STARTUP_MESSAGE=false

# Dashboard web server
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
